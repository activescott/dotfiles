# .<shell>rc stuff for bash and zsh

# Fall back to xterm-256color when the terminal's terminfo isn't installed
# (e.g. Ghostty sets TERM=xterm-ghostty, which remote servers lack, breaking
# backspace/cursor movement over SSH).
if [ -n "$TERM" ] && ! infocmp "$TERM" >/dev/null 2>&1; then
  export TERM=xterm-256color
fi

FALSE=
TRUE=0

#####
# detect host OS
#####
IS_WINDOWS=$FALSE
IS_MAC=$FALSE
IS_LINUX=$FALSE

if [ "$(uname)" = "Darwin" ]
then
	echo running under Mac OS X platform
	IS_MAC=$TRUE
elif [ "$(expr substr $(uname -s) 1 5)" = "Linux" ]
then
	IS_LINUX=$TRUE
	echo running under Linux platform
elif [ -n "$COMSPEC" -a -x "$COMSPEC" ]
then
	echo $0: running under Windows?
	IS_WINDOWS=$TRUE
fi
echo "current shell is $SHELL"

#####
# Import any secrets
#####
if [ -f ~/.secrets ]
then
	echo "sourcing ~/.secrets"
	source ~/.secrets
fi

#####
# PATH variable
#####
# NOTE: About paths: http://serverfault.com/a/146142/28798 (i.e. drop files /etc/paths.d $PATH only works in terminal )
[ $IS_LINUX ] && export PATH="$PATH:/home/linuxbrew/.linuxbrew/bin" # homebrew bin folder on linux (appended so system python/ansible aren't shadowed)
[ $IS_MAC ] && export PATH="/opt/homebrew/bin:$PATH" # homebrew on Apple Silicon: https://docs.brew.sh/Installation


[ $IS_MAC ] && export PATH="/opt/homebrew/sbin:$PATH" # Homebrew's "sbin" on Apple Silicon
[ $IS_LINUX ] && export PATH="$PATH:/home/linuxbrew/.linuxbrew/sbin" # Homebrew's "sbin" on Linux
export PATH="$PATH:/Users/scott/Library/Python/3.11/bin" # python 3.11 pip3 install --user directory on mac
export PATH="$PATH:/usr/sbin" # non-essential system binaries
export PATH="$HOME/bin:$PATH" # my user-local bin folder
export PATH="$PATH:$HOME/.local/bin" # for airbyte-ci: https://github.com/airbytehq/airbyte/blob/master/airbyte-ci/connectors/pipelines/README.md
export PATH="$PATH:/Users/scott/.codeium/windsurf/bin"

# https://developer.1password.com/docs/ssh/get-started/#step-4-configure-your-ssh-or-git-client
# Only set this on macOS, not on Linux where we use forwarded agents
if [[ "$(uname -s)" == "Darwin" ]]; then

    # only set if we're not already in a remote ssh session:
    if [[ -z "$SSH_CLIENT" ]]; then
        export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
    fi
fi

#####
# aliases
#####
alias ls='ls -AlGFh'
alias ll='ls -AlGFh'
alias rm='rm -i'
alias grep='grep --color=auto'
alias gdiff='git diff --color --cached'
alias sha256='shasum -a 256'
[ $IS_MAC ] && alias top='top -o cpu'
[ $IS_LINUX ] && alias top='top -o %CPU'
alias json='python -m json.tool' # http://stackoverflow.com/a/1920585/51061
alias lso="ls -alG | awk '{k=0;for(i=0;i<=8;i++)k+=((substr(\$1,i+2,1)~/[rwx]/)*2^(8-i));if(k)printf(\" %0o \",k);print}'" #http://agileadam.com/2011/02/755-style-permissions-with-ls/

[ $IS_LINUX ] && alias pigs='ps -eo pid,pmem,rss,args --sort=-rss | head -11 | awk '\''{printf "%s\t%.1f%%\t%s\t", $1, $2, $3/1024 "MB"; for(i=4;i<=NF;i++) printf "%s ", $i; printf "\n"}'\'' | column -t'
[ $IS_MAC ] && alias pigs='ps -eo pid,pmem,rss,args -m | head -11 | awk '\''{printf "%s\t%.1f%%\t%s\t", $1, $2, $3/1024 "MB"; for(i=4;i<=NF;i++) printf "%s ", $i; printf "\n"}'\'' | column -t'

# rsos stuff:
if [ -f ~/.shrc-rsos -o -h ~/.shrc-rsos ]
then
	echo "sourcing .shrc-rsos"
	source ~/.shrc-rsos
fi

# onlykey-agent stuff. see https://docs.crp.to/onlykey-agent.html
# use like `okgit pull`
alias okgit="onlykey-agent git@github.com -- git"
# onlykey-agent connect via ssh. Use like `okssh scott@bitbox.activescott.com`
alias okssh="onlykey-agent --connect"

# VS Code launcher + EDITOR setup.
# Uses an alias (not a function) so re-sourcing this file doesn't recurse:
# `command -v code` would otherwise re-detect a previously-defined function
# and the function would call itself instead of the real binary.
# For `code` on PATH on mac, run "Shell Command: Install 'code' command in PATH"
# from the VS Code command palette. See https://code.visualstudio.com/docs/setup/mac#_launching-from-the-command-line
unalias code 2>/dev/null
unset -f code 2>/dev/null

CODE_BIN=$(command -v code 2>/dev/null)
if [ -z "$CODE_BIN" ]; then
	for candidate in /usr/local/bin/code /usr/bin/code "/c/Program Files/Microsoft VS Code/bin/code"; do
		if [ -x "$candidate" ]; then
			CODE_BIN="$candidate"
			break
		fi
	done
fi

# EDITOR must be a command git can prepend to a filename: absolute binary,
# no $@, no trailing ';'.
if [ -n "$CODE_BIN" ]; then
	if [ $IS_LINUX ]; then
		alias code="'$CODE_BIN' --disable-gpu"
		export EDITOR="$CODE_BIN --disable-gpu -w"
	else
		alias code="'$CODE_BIN'"
		export EDITOR="$CODE_BIN -w"
	fi
else
	if command -v nano >/dev/null 2>&1; then
		export EDITOR=nano
	elif command -v vim >/dev/null 2>&1; then
		export EDITOR=vim
	else
		export EDITOR=vi
	fi
fi
unset CODE_BIN candidate

if [ $IS_MAC ]
then
	alias nuget='mono /usr/local/bin/nuget.exe'
	alias shred='rm -P' # mac doesn't include gnu shred, but uses -P with rm
fi

# Prevent some items from going into .bash_history (https://www.gnu.org/software/bash/manual/html_node/Bash-Variables.html) 
# Also works on zsh by looking at `man zshparam` and looking in there
export HISTSIZE=50
export HISTFILESIZE=50
export HISTIGNORE="bitcoind walletpassphrase*:./bitcoind walletpassphrase*:btc walletpassphrase*"

function ghpr() {
	# will list the PRs in the current repo, giving you a preview and selecting one will checkout that PR/branch for you
  GH_FORCE_TTY=100% gh pr list | fzf --ansi --preview 'GH_FORCE_TTY=100% gh pr view {1}' --preview-window down --header-lines 3 | awk '{print $1}' | xargs gh pr checkout
}

function ghdev() {
	# will list issues in the current repo with preview and selecting one will create and checkout a branch named after the issue, it also links the branch to the PR so github can automate ticket status.
  GH_FORCE_TTY=100% gh issue list | fzf --ansi --preview 'GH_FORCE_TTY=100% gh issue view {1}' --preview-window down --header-lines 3 | awk '{print $1}' | sed 's/^#//g' | xargs gh issue develop -c
}


# nvm config per https://github.com/Homebrew/homebrew-core/blob/HEAD/Formula/n/nvm.rb#L34
which brew
if [ $? -eq 0 ]; then
	brew_prefix=$(brew --prefix)
	export NVM_DIR="$HOME/.nvm"
	[ -s "$brew_prefix/opt/nvm/nvm.sh" ] && \. "$brew_prefix/opt/nvm/nvm.sh"  # This loads nvm
	[ -s "$brew_prefix/opt/nvm/etc/bash_completion.d/nvm" ] && \. "$brew_prefix/opt/nvm/etc/bash_completion.d/nvm"  # This loads nvm bash_completion
else
	echo "Brew not installed, skipping nvm configuation"
fi

# flux completion (assumes flux cli is installed via brew)
which flux
if [ $? -eq 0 ]; then
  source <(flux completion zsh)
  echo "flux completions installed"
else
  echo "flux not installed, skipping flux completions"
fi

# huggingface cache dir. See
# https://huggingface.co/docs/huggingface_hub/guides/manage-cache
#   and https://huggingface.co/docs/datasets/cache
if [ $IS_MAC ]
then
	export HF_HOME=/Volumes/stack/.cache/huggingface
fi
