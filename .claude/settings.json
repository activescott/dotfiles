{
  "permissions": {
    "allow": [
      "Bash(sleep *)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/confirm-before-run.sh"
          }
        ]
      }
    ]
  },
  "alwaysThinkingEnabled": true
}
